generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  user
  owner
  admin
}

enum PropertyStatus {
  available
  booked
  maintenance
  inactive
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum PropertyType {
  apartment
  villa
  house
  studio
  penthouse
  townhouse
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role             Role      @default(user)
  isSuspended      Boolean   @default(false)
  suspendedAt      DateTime?
  suspendedReason  String?
  lastLoginAt      DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  bookings        Booking[]
  favorites       Favorite[]
  reviews         Review[]
  submissions     PropertySubmission[]
  notifications   Notification[]
  ownedProperties Property[] @relation("OwnedProperties")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Property {
  id             String         @id @default(cuid())
  title          String
  slug           String         @unique
  description    String         @db.Text
  propertyType   PropertyType   @default(apartment)
  pricePerNight  Decimal        @db.Decimal(10, 2)
  bedrooms       Int            @default(1)
  bathrooms      Decimal        @db.Decimal(3, 1) @default(1)
  maxGuests      Int            @default(2)
  city           String         @default("Accra")
  address        String?
  lat            Decimal?       @db.Decimal(10, 8)
  lng            Decimal?       @db.Decimal(11, 8)
  area           Int?
  areaUnit       String?        @default("sqft")
  amenities      String[]
  featured       Boolean        @default(false)
  status         PropertyStatus @default(available)
  hasVirtualTour     Boolean        @default(false)
  virtualTourUrl     String?
  lodgifyPropertyId  String?
  lodgifyRoomTypeId  String?
  createdAt          DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  ownerId   String?

  images    PropertyImage[]
  bookings  Booking[]
  favorites Favorite[]
  reviews   Review[]
  owner     User?  @relation("OwnedProperties", fields: [ownerId], references: [id], onDelete: SetNull)

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  imageUrl   String
  publicId   String?
  isPrimary  Boolean  @default(false)
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Booking {
  id              String        @id @default(cuid())
  reference       String        @unique
  propertyId      String
  userId          String?
  guestName       String
  guestEmail      String
  guestPhone      String?
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  nights          Int
  pricePerNight   Decimal       @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  status          BookingStatus @default(pending)
  paymentStatus   PaymentStatus @default(pending)
  paymentMethod   String?
  paystackRef     String?
  specialRequests String?       @db.Text
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@map("bookings")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Review {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  rating     Int
  comment    String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model GalleryImage {
  id        String   @id @default(cuid())
  imageUrl  String
  publicId  String?
  caption   String?
  category  String   @default("Interior")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model Tour {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String   @db.Text
  date            DateTime
  time            String   @default("10:00")
  duration        String   @default("3 hours")
  meetingPoint    String   @default("")
  maxParticipants Int      @default(20)
  price           Decimal  @db.Decimal(10, 2) @default(0)
  image           String?
  publicId        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  registrations TourRegistration[]

  @@map("tours")
}

model TourRegistration {
  id                 String    @id @default(cuid())
  tourId             String?
  fullName           String
  email              String
  phone              String
  country            String?
  tourDate           DateTime?
  groupSize          Int       @default(1)
  needsAccommodation Boolean   @default(false)
  specialNeeds       String?   @db.Text
  status             String    @default("pending")
  createdAt          DateTime  @default(now())

  tour Tour? @relation(fields: [tourId], references: [id])

  @@map("tour_registrations")
}

model PropertySubmission {
  id            String   @id @default(cuid())
  submissionRef String   @unique
  userId        String?
  fullName      String
  email         String
  phone         String
  propertyType  String?
  location      String?
  bedrooms      Int?
  bathrooms     Int?
  maxGuests     Int?
  priceEstimate Decimal? @db.Decimal(10, 2)
  description   String?  @db.Text
  message       String?  @db.Text
  amenities     String[]
  images        String[]
  status        String   @default("pending")
  adminNote     String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("property_submissions")
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("site_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String   @db.Text
  type      String   @default("info") // info | success | warning | error
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PaymentConfig {
  id          String   @id @default(cuid())
  provider    String   @default("bizify") // bizify | paystack | manual
  apiKey      String?  @db.Text
  secretKey   String?  @db.Text
  webhookUrl  String?
  isLive      Boolean  @default(false)
  isActive    Boolean  @default(true)
  extra       String?  @db.Text  // JSON for additional config
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("payment_configs")
}

model OwnerWallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Decimal  @default(0) @db.Decimal(12, 2)
  pendingBalance Decimal @default(0) @db.Decimal(12, 2)
  currency      String   @default("GHS")
  bizifyId      String?  // External Bizify wallet ID
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("owner_wallets")
}
